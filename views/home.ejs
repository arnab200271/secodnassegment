<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Home Page</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .product-card {
      width: 18rem;
      margin: 10px;
    }
    .card-img-top {
      height: 150px;
      object-fit: cover;
    }
  </style>
</head>
<body>

<div class="container mt-4">
  <h2 class="mb-4">Our Products</h2>
  <div class="row">
    <% products.forEach(prod => { %>
      <div class="col-md-3">
        <div class="card product-card">
          <% if(prod.image){ %>
            <img src="/uploads/<%= prod.image %>" class="card-img-top" alt="<%= prod.name %>">
          <% } %>
          <div class="card-body">
            <h5 class="card-title"><%= prod.name %></h5>
            <p class="card-text"><%= prod.description.substring(0, 50) %>...</p>
            <p class="text-muted"><%= prod.category ? prod.category.name : 'N/A' %></p>
            <!-- Admin dashboard button -->
            <a href="/admin/dashboard" class="btn btn-primary btn-sm">Admin Dashboard</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>

</body>
</html>