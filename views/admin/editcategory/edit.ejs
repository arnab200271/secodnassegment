<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Category</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow">
                <div class="card-header text-center">
                    <h4>Edit Category</h4>
                </div>

                <div class="card-body">

                    <!-- Form -->
                    <form action="/admin/categories/update/<%= category._id %>" method="POST">

                        <div class="mb-3">
                            <label class="form-label">Category Name</label>
                            <input 
                                type="text" 
                                name="name" 
                                class="form-control" 
                                value="<%= category.name %>"
                                placeholder="Enter category name"
                            >
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-warning">
                                Update Category
                            </button>
                        </div>

                    </form>

                    <!-- Back Button -->
                    <div class="mt-3 text-center">
                        <a href="/cat/list" class="btn btn-secondary btn-sm">
                            Back to List
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

</body>
</html>